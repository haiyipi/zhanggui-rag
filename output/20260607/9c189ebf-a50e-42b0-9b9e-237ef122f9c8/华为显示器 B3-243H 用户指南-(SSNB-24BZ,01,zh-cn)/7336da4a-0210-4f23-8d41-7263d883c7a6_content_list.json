        "table_body": "<table><tr><td>分辨率</td><td>HDMI刷新率</td><td>DP刷新率</td></tr><tr><td>640 x 480</td><td>60Hz</td><td>60Hz</td></tr><tr><td>640 x 480</td><td>67Hz</td><td>67Hz</td></tr><tr><td>640 x 480</td><td>72Hz</td><td>72Hz</td></tr><tr><td>640 x 480</td><td>75Hz</td><td>75Hz</td></tr><tr><td>720 x 400</td><td>70Hz</td><td>70Hz</td></tr><tr><td>800 x 600</td><td>56Hz</td><td>56Hz</td></tr><tr><td>800 x 600</td><td>60Hz</td><td>60Hz</td></tr><tr><td>800 x 600</td><td>72Hz</td><td>72Hz</td></tr><tr><td>800 x 600</td><td>75Hz</td><td>75Hz</td></tr><tr><td>832 x 624</td><td>75Hz</td><td>75Hz</td></tr><tr><td>1024 x 768</td><td>60Hz</td><td>60Hz</td></tr><tr><td>1024 x 768</td><td>70Hz</td><td>70Hz</td></tr><tr><td>1024 x 768</td><td>75Hz</td><td>75Hz</td></tr><tr><td>1280 x 1024</td><td>60Hz</td><td>60Hz</td></tr><tr><td>1280 x 1024</td><td>75Hz</td><td>75Hz</td></tr><tr><td>1280 x 720</td><td>60Hz</td><td>60Hz</td></tr><tr><td>1280 x 960</td><td>60Hz</td><td>60Hz</td></tr><tr><td>1440 x 900</td><td>60Hz</td><td>60Hz</td></tr><tr><td>1680 x 1050</td><td>60Hz</td><td>60Hz</td></tr><tr><td>1920 x 1080</td><td>60Hz</td><td>60Hz</td></tr><tr><td>1920 x 1080</td><td>75Hz</td><td>75Hz</td></tr></table>",
