    {
        "type": "text",
        "text": "认证信息",
        "text_level": 1,
        "bbox": [
            70,
            49,
            157,
            67
        ],
        "page_idx": 8
    },
    {
        "type": "text",
        "text": "请在产品铭牌上查看型号核准代码。",
        "bbox": [
            70,
            76,
            389,
            93
        ],
        "page_idx": 8
    },
    {
