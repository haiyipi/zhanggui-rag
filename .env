# ==================== MinerU 配置 ====================
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_OFFLINE=1
MODELSCOPE_CACHE=D:/ai_models/modelscope_cache
HF_HOME=D:/ai_models/huggingface_cache
MD_ROOT_DIR=./temp-files/

# ==================== 大模型配置 ====================
LLM_DEFAULT_MODEL=qwen-flash
VL_MODEL=qwen-max
OPENAI_API_KEY=sk-6d248ae0f11e4f579b7487c2cfb0e53e
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_TEMPERATURE=0.1

# ==================== Embedding 模型配置 ====================
# 使用本地下载的 BGE-M3 模型（D盘）
BGE_M3_PATH=D:/ai_models/modelscope_cache/BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=0
ITEM_NAME_DIAG=1

# ==================== Milvus 配置 ====================
MILVUS_URL=http://localhost:19530
CHUNKS_COLLECTION=kb_chunks
ENTITY_NAME_COLLECTION=kb_graph_entity_names
ITEM_NAME_COLLECTION=kb_item_names

EMBEDDING_DIM=1536
MILVUS_METRIC_TYPE=COSINE
MILVUS_MIN_COSINE_SCORE=0.75

# ==================== Neo4j 配置 ====================
NEO4J_URI=bolt://192.168.11.104:7687
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=123123123

# ==================== MongoDB 配置 ====================
MONGO_URL=mongodb://root:root123@localhost:27017
MONGO_DB_NAME=kb002

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# ==================== 重排序模型配置 ====================
BGE_RERANKER_LARGE=D:/ai_models/modelscope_cache/BAAI/bge-reranker-large
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_FP16=0

